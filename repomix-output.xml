            SmallIconPath = $"{basePath}/tiles/icons/{tileCode}_small.png",
            DiscardSfxPath = $"{ResourcePathConstants.Sfx}/tile_discard.ogg",
            DrawSfxPath = $"{ResourcePathConstants.Sfx}/tile_draw.ogg"
        };
    }

    /// <summary>
    /// 用 Mod 路径约定创建。
