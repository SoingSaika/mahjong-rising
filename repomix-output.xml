    /// <summary>牌背贴图路径（默认使用全局牌背，可单独覆盖）。</summary>
    public string? BackTexturePath { get; set; }

    // ── 2D UI 资源 ──

    /// <summary>手牌 UI 图标路径（较大，用于手牌区显示）。</summary>
